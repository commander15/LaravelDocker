#!/usr/bin/env sh

# Define the target directory path
TARGET_DIR="/home/laravel/startup/bin"

# Loop through all .sh files in that folder
for script in "$TARGET_DIR"/*.sh; do
    # Check if any matching files actually exist to avoid errors
    [ -e "$script" ] || continue
    
    echo "Running: $script"
    sh "$script"
done

# If GIT_URL is defined and git is installed, clone the repository and remove everything else
if [ -n "$GIT_URL" ] && [ -f "/usr/bin/git" ]; then
    rm -rf /var/www/html/*
    git clone --depth 1 $GIT_URL /var/www/html/
fi

# Running supervisor
/usr/bin/supervisord -n -c "/etc/supervisor/supervisord.conf"